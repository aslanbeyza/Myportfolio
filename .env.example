# Environment template — copy to .env.local for development (never commit secrets).
# Production / Vercel: paste these keys in the host dashboard (or use .env.production.local locally only).

# ==========================================
# REQUIRED - Gmail SMTP Configuration
# ==========================================
GMAIL_USER=your-email@gmail.com
# * Replace with a Gmail App Password (16+ characters) from
#   https://myaccount.google.com/apppasswords
GMAIL_APP_PASSWORD=your-16-character-app-password

# ==========================================
# OPTIONAL - Email Configuration
# ==========================================
# If not set, defaults to GMAIL_USER
EMAIL_TO=your-email@gmail.com

# Currently unused; uncomment only if your code uses them
# EMAIL_FROM=your-email@gmail.com
# CONTACT_SECRET=your-contact-secret

# ==========================================
# REQUIRED - Site Configuration
# ==========================================
# For local dev use http://localhost:3000 – use your real domain in production
NEXT_PUBLIC_BASE_URL=https://your-domain.com
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# ==========================================
# REQUIRED - Personal Information
# ==========================================
NEXT_PUBLIC_FULL_NAME=BEYZA ASLAN
NEXT_PUBLIC_JOB_TITLE=Software Developer
NEXT_PUBLIC_COMPANY=Freelance

# ==========================================
# REQUIRED - Contact Information
# ==========================================
NEXT_PUBLIC_CONTACT_EMAIL=aslanbeyza3413@gmail.com
NEXT_PUBLIC_CONTACT_LOCATION=Istanbul, Turkey
NEXT_PUBLIC_CONTACT_PHONE=+90 (530) 061 49 02
NEXT_PUBLIC_CONTACT_PHONE_WITHOUT_SPACE=+905300614902

# ==========================================
# REQUIRED - Social Media Links
# ==========================================
NEXT_PUBLIC_GITHUB_URL=https://github.com/aslanbeyza
NEXT_PUBLIC_LINKEDIN_URL=https://www.linkedin.com/in/beyza-aslan/

# ==========================================
# OPTIONAL - Social Media
# ==========================================
# NEXT_PUBLIC_TWITTER_HANDLE=yourusername

# ==========================================
# OPTIONAL - Analytics & Verification
# ==========================================
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_GOOGLE_VERIFICATION=your-google-verification-code

# ==========================================
# OPTIONAL - Security (rate limiting, captcha)
# ==========================================
# NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your-recaptcha-site-key
# UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-redis-token
