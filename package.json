{
  "name": "portfolio-website",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@11.8.0",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "npm run validate:env:production && next build --turbopack",
    "start": "next start",
    "lint": "eslint",
    "vercel-build": "dotenvx run --env-file=.env.production -- npm run validate:env:production && dotenvx run --env-file=.env.production -- next build",
    "type-check": "tsc --noEmit",
    "validate:env": "tsx scripts/validate-env.ts --mode=development",
    "validate:env:production": "tsx scripts/validate-env.ts --mode=production",
    "validate:env:production:encrypted": "dotenvx run --env-file=.env.production -- npm run validate:env:production",
    "sync:env:production": "tsx scripts/sync-production-env.ts",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "analyze": "ANALYZE=true next build",
    "build:encrypted": "dotenvx run --env-file=.env.production -- npm run build",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:headed": "playwright test --headed",
    "pre-commit": "npm run lint && npm run type-check && npm run validate:env && npm run test:run"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@next/env": "16.1.7",
    "@next/third-parties": "^16.1.7",
    "@radix-ui/react-slot": "^1.2.4",
    "@types/nodemailer": "^7.0.11",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.577.0",
    "next": "^16.1.7",
    "nodemailer": "^8.0.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.71.2",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@dotenvx/dotenvx": "^1.55.1",
    "@eslint/eslintrc": "^3.3.5",
    "@next/bundle-analyzer": "^16.1.7",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "dotenv": "^17.3.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.1.7",
    "jsdom": "^29.0.0",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.0",
    "vitest": "^4.1.0"
  }
}
